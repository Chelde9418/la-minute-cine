rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isEmailVerified() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Helpers
    function isValidArticle(data) {
      return data.keys().hasAll(['title', 'category', 'content', 'id']) &&
             data.title is string && data.title.size() <= 200 &&
             data.category is string &&
             data.content is string && data.content.size() <= 65536 &&
             data.id is string && data.id.size() <= 128;
    }

    // Match Blocks
    match /articles/{articleId} {
      allow read: if true;
      allow create: if isAdmin() && isValidArticle(incoming()) && isValidId(articleId);
      allow update: if isAdmin() && isValidArticle(incoming());
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Only manageable through Firebase Console or Cloud Functions
    }
  }
}
